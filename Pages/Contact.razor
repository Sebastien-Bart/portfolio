@page "/contact"
@inject LanguageService Lang
@implements IDisposable

<PageTitle>Contact — Sébastien Bart</PageTitle>

<!-- HERO -->
<div class="page-hero">
    <div class="container">
        <h1>@Lang.T("contact.hero.title")</h1>
        <p>@Lang.T("contact.hero.subtitle")</p>
    </div>
</div>

<!-- MAIN CONTENT -->
<div class="section-full">
    <div class="section">
        <div class="grid-2" style="align-items: start; gap: 3rem;">

            <!-- CONTACT INFO -->
            <div>
                <h2 class="section-title"><span class="title-accent">—</span> @Lang.T("contact.info.title")</h2>

                <div class="contact-info-item card-yellow">
                    <span class="contact-icon">📧</span>
                    <div class="contact-info-text">
                        <strong>@Lang.T("contact.info.email.label")</strong>
                        <span>sebastien0bart&#64;gmail.com</span>
                    </div>
                </div>

                <div class="contact-info-item">
                    <span class="contact-icon">📍</span>
                    <div class="contact-info-text">
                        <strong>@Lang.T("contact.info.location.label")</strong>
                        <span>Ornans, France</span>
                    </div>
                </div>

                <div class="contact-info-item">
                    <span class="contact-icon">💼</span>
                    <div class="contact-info-text">
                        <strong>@Lang.T("contact.info.linkedin.label")</strong>
                        <span>linkedin.com/in/sébastien-bart-91353617b</span>
                    </div>
                    <a href="https://www.linkedin.com/in/sébastien-bart-91353617b" target="_blank"
                       class="btn btn-secondary" style="flex-shrink: 0;">@Lang.T("contact.btn.go")</a>
                </div>

                <div class="contact-info-item">
                    <span class="contact-icon">🐙</span>
                    <div class="contact-info-text">
                        <strong>@Lang.T("contact.info.github.label")</strong>
                        <span>github.com/sebastien-bart</span>
                    </div>
                    <a href="https://github.com/sebastien-bart" target="_blank"
                       class="btn btn-secondary" style="flex-shrink: 0;">@Lang.T("contact.btn.go")</a>
                </div>

                <!-- Availability card -->
                <div class="card card-navy" style="margin-top: 1.5rem;">
                    <h3 class="card-title" style="color: var(--yellow);">@Lang.T("contact.availability.title")</h3>
                    <p class="card-text" style="margin-top: 0.5rem;">@((MarkupString)Lang.T("contact.availability.text"))</p>
                    <p class="card-text" style="margin-top: 0.5rem; font-size: 0.85rem; opacity: 0.75;">
                        @Lang.T("contact.availability.response")
                    </p>
                </div>
            </div>

        </div>
    </div>
</div>

@code {
    protected override void OnInitialized() => Lang.OnLanguageChanged += StateHasChanged;
    public void Dispose() => Lang.OnLanguageChanged -= StateHasChanged;
}
