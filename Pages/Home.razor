@page "/"

<PageTitle>Home — Portfolio</PageTitle>

<!-- INTRO -->
<section style="border-bottom: 3px solid var(--dark-navy);">
    <div class="intro-wrapper">
        <div class="intro-avatar">👤</div>
        <div class="intro-text">
            <h1>Lorem <span class="highlight">Ipsum</span></h1>
            <span class="role">Full-Stack Developer</span>
            <p>
                Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.
                Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris.
            </p>
            <div class="intro-actions">
                <a href="/projects" class="btn btn-primary">View Projects</a>
                <a href="/contact" class="btn btn-secondary">Contact Me</a>
            </div>
        </div>
    </div>
</section>

<!-- MARQUEE BANNER -->
<div class="marquee-banner">
    <span class="marquee-content">
        ✦ DEVELOPER &nbsp;&nbsp;&nbsp; ✦ DESIGNER &nbsp;&nbsp;&nbsp; ✦ PROBLEM SOLVER &nbsp;&nbsp;&nbsp; ✦ OPEN TO OPPORTUNITIES &nbsp;&nbsp;&nbsp;
        ✦ DEVELOPER &nbsp;&nbsp;&nbsp; ✦ DESIGNER &nbsp;&nbsp;&nbsp; ✦ PROBLEM SOLVER &nbsp;&nbsp;&nbsp; ✦ OPEN TO OPPORTUNITIES &nbsp;&nbsp;&nbsp;
    </span>
</div>

<!-- STATS -->
<div class="section-full" style="background-color: var(--dark-navy); color: var(--off-white);">
    <div class="section">
        <div class="grid-4">
            <div class="stat-box" style="background-color: var(--red); border-color: var(--off-white); box-shadow: 4px 4px 0 var(--off-white);">
                <div class="stat-number" style="color: var(--off-white);">3+</div>
                <div class="stat-label" style="color: var(--off-white);">Years of Experience</div>
            </div>
            <div class="stat-box" style="background-color: var(--yellow); border-color: var(--off-white); box-shadow: 4px 4px 0 var(--off-white);">
                <div class="stat-number" style="color: var(--dark-navy);">12+</div>
                <div class="stat-label" style="color: var(--dark-navy);">Projects Completed</div>
            </div>
            <div class="stat-box" style="background-color: var(--teal); border-color: var(--off-white); box-shadow: 4px 4px 0 var(--off-white);">
                <div class="stat-number" style="color: var(--off-white);">8+</div>
                <div class="stat-label" style="color: var(--off-white);">Technologies Used</div>
            </div>
            <div class="stat-box" style="background-color: var(--orange); border-color: var(--off-white); box-shadow: 4px 4px 0 var(--off-white);">
                <div class="stat-number" style="color: var(--off-white);">2</div>
                <div class="stat-label" style="color: var(--off-white);">Diplomas Earned</div>
            </div>
        </div>
    </div>
</div>

<!-- EDUCATION -->
<div class="section-full section-alt">
    <div class="section">
        <h2 class="section-title"><span class="title-accent">—</span> Education</h2>
        <div class="grid-2">
            <div class="diploma-card card-yellow">
                <span class="diploma-year">2023</span>
                <h3 class="card-title">Master of Science in Computer Science</h3>
                <p class="card-meta">University of Lorem Ipsum &mdash; Paris, France</p>
                <p class="card-text">
                    Specialisation in Software Engineering and Distributed Systems. Graduated with honors.
                    Thesis on cloud-native microservice architectures.
                </p>
                <div class="tags">
                    <span class="tag">Computer Science</span>
                    <span class="tag tag-teal">Distributed Systems</span>
                </div>
            </div>
            <div class="diploma-card card-light-blue">
                <span class="diploma-year">2021</span>
                <h3 class="card-title">Bachelor of Engineering — Software</h3>
                <p class="card-meta">Institut Lorem Ipsum &mdash; Lyon, France</p>
                <p class="card-text">
                    Core curriculum covering algorithms, data structures, databases, and web development.
                    Final year project: real-time collaborative editor.
                </p>
                <div class="tags">
                    <span class="tag">Software Engineering</span>
                    <span class="tag tag-blue">Web Dev</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- WORK EXPERIENCE -->
<div class="section-full">
    <div class="section">
        <h2 class="section-title"><span class="title-accent">—</span> Work Experience</h2>
        <div class="timeline">
            <div class="timeline-item">
                <h3 class="timeline-title">Senior Full-Stack Developer</h3>
                <p class="timeline-meta">Lorem Corp. &mdash; Paris, France &nbsp;|&nbsp; Jan 2023 – Present</p>
                <p class="timeline-text">
                    Lorem ipsum dolor sit amet, consectetur adipiscing elit. Developed and maintained scalable
                    microservices using .NET and React. Led a team of 4 engineers and coordinated with product
                    stakeholders to deliver features on schedule.
                </p>
                <div class="tags">
                    <span class="tag tag-blue">.NET</span>
                    <span class="tag">React</span>
                    <span class="tag tag-teal">Azure</span>
                    <span class="tag tag-orange">Docker</span>
                </div>
            </div>
            <div class="timeline-item">
                <h3 class="timeline-title">Full-Stack Developer</h3>
                <p class="timeline-meta">Ipsum Solutions — Lyon, France &nbsp;|&nbsp; Jun 2021 – Dec 2022</p>
                <p class="timeline-text">
                    Designed and built REST APIs and SPA dashboards for enterprise clients. Implemented CI/CD
                    pipelines and reduced deployment time by 40%. Collaborated in an Agile team of 8 developers.
                </p>
                <div class="tags">
                    <span class="tag tag-blue">ASP.NET Core</span>
                    <span class="tag">Angular</span>
                    <span class="tag tag-teal">PostgreSQL</span>
                </div>
            </div>
            <div class="timeline-item">
                <h3 class="timeline-title">Software Developer Intern</h3>
                <p class="timeline-meta">Dolor Start-Up — Remote &nbsp;|&nbsp; Feb 2021 – May 2021</p>
                <p class="timeline-text">
                    Contributed to an e-commerce platform rebuild using Vue.js and Node.js. Wrote unit tests
                    and integration tests achieving 80%+ coverage. Participated in daily stand-ups and sprint reviews.
                </p>
                <div class="tags">
                    <span class="tag">Vue.js</span>
                    <span class="tag tag-orange">Node.js</span>
                    <span class="tag">MongoDB</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- SKILLS -->
<div class="section-full section-alt">
    <div class="section">
        <h2 class="section-title"><span class="title-accent">—</span> Skills</h2>
        <div class="grid-2">
            <!-- Technical Skills -->
            <div>
                <h3 style="font-size: 1.2rem; margin-bottom: 1.25rem; letter-spacing: 1px;">Technical Skills</h3>
                <div class="skill-item">
                    <div class="skill-label"><span>C# / .NET</span><span>90%</span></div>
                    <div class="skill-bar"><div class="skill-fill" style="width: 90%;"></div></div>
                </div>
                <div class="skill-item">
                    <div class="skill-label"><span>JavaScript / TypeScript</span><span>85%</span></div>
                    <div class="skill-bar"><div class="skill-fill" style="width: 85%; background-color: var(--orange);"></div></div>
                </div>
                <div class="skill-item">
                    <div class="skill-label"><span>React / Blazor</span><span>80%</span></div>
                    <div class="skill-bar"><div class="skill-fill" style="width: 80%; background-color: var(--teal);"></div></div>
                </div>
                <div class="skill-item">
                    <div class="skill-label"><span>SQL / PostgreSQL</span><span>75%</span></div>
                    <div class="skill-bar"><div class="skill-fill" style="width: 75%; background-color: var(--mid-blue);"></div></div>
                </div>
                <div class="skill-item">
                    <div class="skill-label"><span>Docker / Kubernetes</span><span>65%</span></div>
                    <div class="skill-bar"><div class="skill-fill" style="width: 65%; background-color: var(--yellow);"></div></div>
                </div>
            </div>
            <!-- Soft Skills & Tools -->
            <div>
                <h3 style="font-size: 1.2rem; margin-bottom: 1.25rem; letter-spacing: 1px;">Tools & Soft Skills</h3>
                <div class="grid-2" style="gap: 0.75rem;">
                    <div class="tag" style="text-align: center; padding: 0.6rem; font-size: 0.8rem;">Git / GitHub</div>
                    <div class="tag tag-teal" style="text-align: center; padding: 0.6rem; font-size: 0.8rem;">CI/CD Pipelines</div>
                    <div class="tag tag-orange" style="text-align: center; padding: 0.6rem; font-size: 0.8rem;">Agile / Scrum</div>
                    <div class="tag tag-blue" style="text-align: center; padding: 0.6rem; font-size: 0.8rem;">Azure / AWS</div>
                    <div class="tag" style="text-align: center; padding: 0.6rem; font-size: 0.8rem;">Team Leadership</div>
                    <div class="tag tag-red" style="text-align: center; padding: 0.6rem; font-size: 0.8rem;">Problem Solving</div>
                    <div class="tag tag-teal" style="text-align: center; padding: 0.6rem; font-size: 0.8rem;">Code Review</div>
                    <div class="tag tag-blue" style="text-align: center; padding: 0.6rem; font-size: 0.8rem;">Technical Writing</div>
                </div>
            </div>
        </div>
    </div>
</div>
