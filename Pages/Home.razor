@page "/"
@inject LanguageService Lang
@implements IDisposable

<PageTitle>Home — Sébastien Bart</PageTitle>

<!-- INTRO -->
<section style="border-bottom: 3px solid var(--dark-navy);">
    <div class="intro-wrapper">
        <div class="intro-avatar">
            <img src="images/pp_pro_square.jpg" alt="👤" class="avatar-image" width="100%">
        </div>
        <div class="intro-text">
            <h1>Sébastien <span class="highlight">BART</span></h1>
            <span class="role">@Lang.T("home.role")</span>
            <p>@Lang.T("home.intro")</p>
            <div class="intro-actions">
                <a href="/projects" class="btn btn-primary">@Lang.T("home.btn.projects")</a>
                <a href="/contact" class="btn btn-secondary">@Lang.T("home.btn.contact")</a>
            </div>
        </div>
    </div>
</section>

<!-- MARQUEE BANNER -->
<div class="marquee-banner">
    <span class="marquee-content">
        @((MarkupString)Lang.T("home.marquee")) @((MarkupString)Lang.T("home.marquee"))
    </span>
</div>

<!-- STATS -->
<div class="section-full" style="background-color: var(--dark-navy); color: var(--off-white);">
    <div class="section">
        <div class="grid-4">
            <div class="stat-box" style="background-color: var(--red); border-color: var(--off-white); box-shadow: 4px 4px 0 var(--off-white);">
                <div class="stat-number" style="color: var(--off-white);">4+</div>
                <div class="stat-label" style="color: var(--off-white);">@Lang.T("home.stats.experience")</div>
            </div>
            <div class="stat-box" style="background-color: var(--yellow); border-color: var(--off-white); box-shadow: 4px 4px 0 var(--off-white);">
                <div class="stat-number" style="color: var(--dark-navy);">@Lang.T("home.stats.thousands")</div>
                <div class="stat-label" style="color: var(--dark-navy);">@Lang.T("home.stats.tickets")</div>
            </div>
            <div class="stat-box" style="background-color: var(--teal); border-color: var(--off-white); box-shadow: 4px 4px 0 var(--off-white);">
                <div class="stat-number" style="color: var(--off-white);">10+</div>
                <div class="stat-label" style="color: var(--off-white);">@Lang.T("home.stats.tech")</div>
            </div>
            <div class="stat-box" style="background-color: var(--orange); border-color: var(--off-white); box-shadow: 4px 4px 0 var(--off-white);">
                <div class="stat-number" style="color: var(--off-white);">965</div>
                <div class="stat-label" style="color: var(--off-white);">@Lang.T("home.stats.toeic")</div>
            </div>
        </div>
    </div>
</div>

<!-- EDUCATION -->
<div class="section-full section-alt">
    <div class="section">
        <h2 class="section-title"><span class="title-accent">—</span> @Lang.T("home.education.title")</h2>
        <div class="grid-2">
            <div class="diploma-card card-yellow">
                <span class="diploma-year">2020 - 2022</span>
                <h3 class="card-title">@Lang.T("home.edu.master.title")</h3>
                <p class="card-meta">@Lang.T("home.edu.master.school") &mdash; Lille, France</p>
                <p class="card-text">@Lang.T("home.edu.master.desc")</p>
                <div class="tags">
                    <span class="tag tag-orange">@Lang.T("home.edu.master.tag1")</span>
                    <span class="tag">@Lang.T("home.edu.master.tag2")</span>
                    <span class="tag tag-teal">@Lang.T("home.edu.master.tag3")</span>
                </div>
            </div>
            <div class="diploma-card card-light-blue">
                <span class="diploma-year">2017 - 2020</span>
                <h3 class="card-title">@Lang.T("home.edu.bachelor.title")</h3>
                <p class="card-meta">@Lang.T("home.edu.bachelor.school") &mdash; Lille, France</p>
                <p class="card-text">@Lang.T("home.edu.bachelor.desc")</p>
                <div class="tags">
                    <span class="tag tag-blue">@Lang.T("home.edu.bachelor.tag1")</span>
                    <span class="tag tag-yellow">@Lang.T("home.edu.bachelor.tag2")</span>
                    <span class="tag tag-sage">@Lang.T("home.edu.bachelor.tag3")</span>
                    <span class="tag tag-teal">@Lang.T("home.edu.bachelor.tag4")</span>
                </div>
            </div>
        </div>
        <div class="diploma-card card-teal" style="margin-top: 1.5rem;">
            <span class="diploma-year">2017</span>
            <h3 class="card-title">@Lang.T("home.edu.highschool.title")</h3>
            <p class="card-meta">@Lang.T("home.edu.highschool.school") &mdash; Hazebrouck, France</p>
            <p class="card-text">@Lang.T("home.edu.highschool.desc")</p>
            <div class="tags">
                <span class="tag tag-orange">@Lang.T("home.edu.highschool.tag1")</span>
            </div>
        </div>
    </div>
</div>

<!-- WORK EXPERIENCE -->
<div class="section-full">
    <div class="section">
        <h2 class="section-title"><span class="title-accent">—</span> @Lang.T("home.experience.title")</h2>
        <div class="timeline">
            <div class="timeline-item">
                <h3 class="timeline-title">@Lang.T("home.exp1.title")</h3>
                <p class="timeline-meta">Ankama &mdash; Roubaix, France &nbsp;|&nbsp; @Lang.T("home.exp1.period")</p>
                <p class="timeline-text">@Lang.T("home.exp1.desc")</p>
                <div class="tags">
                    <span class="tag tag-blue">Unity</span>
                    <span class="tag">C# (.NET)</span>
                    <span class="tag tag-teal">Java</span>
                    <span class="tag tag-orange">SQL</span>
                    <span class="tag tag-red">AS3</span>
                    <span class="tag tag-yellow">Oracle</span>
                    <span class="tag tag-light">Youtrack</span>
                    <span class="tag tag-sage">Gitlab</span>
                    <span class="tag tag-blue">UI / UX</span>
                </div>
            </div>
            <div class="timeline-item">
                <h3 class="timeline-title">@Lang.T("home.exp2.title")</h3>
                <p class="timeline-meta">Decathlon &mdash; Croix, France &nbsp;|&nbsp; @Lang.T("home.exp2.period")</p>
                <p class="timeline-text">@Lang.T("home.exp2.desc")</p>
                <div class="tags">
                    <span class="tag tag-blue">Splunk</span>
                    <span class="tag">SQL</span>
                    <span class="tag tag-teal">Java</span>
                    <span class="tag tag-orange">PostgreSQL</span>
                    <span class="tag tag-red">Oracle</span>
                    <span class="tag tag-yellow">Javascript</span>
                    <span class="tag tag-light">Google Suite</span>
                    <span class="tag tag-sage">Scrum</span>
                    <span class="tag tag-blue">ITIL</span>
                    <span class="tag">SRE (System Reliability Engineering)</span>
                </div>
            </div>
            <div class="timeline-item">
                <h3 class="timeline-title">@Lang.T("home.exp3.title")</h3>
                <p class="timeline-meta">INRIA &mdash; Villeneuve d'Ascq, France &nbsp;|&nbsp; @Lang.T("home.exp3.period")</p>
                <p class="timeline-text">@Lang.T("home.exp3.desc")</p>
                <div class="tags">
                    <span class="tag tag-blue">C#</span>
                    <span class="tag">Unity</span>
                    <span class="tag tag-teal">Mirror</span>
                    <span class="tag tag-orange">Jenkins</span>
                    <span class="tag tag-red">Docker</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- SKILLS -->
<div class="section-full section-alt">
    <div class="section">
        <h2 class="section-title"><span class="title-accent">—</span> @Lang.T("home.skills.title")</h2>
        <div class="grid-2">
            <!-- Technical Skills -->
            <div>
                <h3 style="font-size: 1.2rem; margin-bottom: 1.25rem; letter-spacing: 1px;">@Lang.T("home.skills.technical")</h3>
                <div class="skill-item">
                    <div class="skill-label"><span>C# / .NET</span><span>90%</span></div>
                    <div class="skill-bar"><div class="skill-fill" style="width: 90%;"></div></div>
                </div>
                <div class="skill-item">
                    <div class="skill-label"><span>Java</span><span>85%</span></div>
                    <div class="skill-bar"><div class="skill-fill" style="width: 85%; background-color: var(--orange);"></div></div>
                </div>
                <div class="skill-item">
                    <div class="skill-label"><span>Javascript / Typescript</span><span>70%</span></div>
                    <div class="skill-bar"><div class="skill-fill" style="width: 70%; background-color: var(--teal);"></div></div>
                </div>
                <div class="skill-item">
                    <div class="skill-label"><span>Splunk</span><span>70%</span></div>
                    <div class="skill-bar"><div class="skill-fill" style="width: 70%; background-color: var(--mid-blue);"></div></div>
                </div>
                <div class="skill-item">
                    <div class="skill-label"><span>SQL / PostgreSQL / Oracle SQL</span><span>80%</span></div>
                    <div class="skill-bar"><div class="skill-fill" style="width: 80%; background-color: var(--dark-navy);"></div></div>
                </div>
                <div class="skill-item">
                    <div class="skill-label"><span>HTML / CSS</span><span>90%</span></div>
                    <div class="skill-bar"><div class="skill-fill" style="width: 90%; background-color: var(--light-blue);"></div></div>
                </div>
                <div class="skill-item">
                    <div class="skill-label"><span>Python</span><span>70%</span></div>
                    <div class="skill-bar"><div class="skill-fill" style="width: 70%; background-color: var(--yellow);"></div></div>
                </div>
                <div class="skill-item">
                    <div class="skill-label"><span>ASP.NET / Blazor</span><span>90%</span></div>
                    <div class="skill-bar"><div class="skill-fill" style="width: 90%;"></div></div>
                </div>
                <div class="skill-item">
                    <div class="skill-label"><span>C++</span><span>70%</span></div>
                    <div class="skill-bar"><div class="skill-fill" style="width: 70%; background-color: var(--teal);"></div></div>
                </div>
            </div>
            <!-- Tools & Soft Skills -->
            <div>
                <h3 style="font-size: 1.2rem; margin-bottom: 1.25rem; letter-spacing: 1px;">@Lang.T("home.skills.tools")</h3>
                <div class="grid-2" style="gap: 0.75rem;">
                    <div class="tag tag-blue" style="text-align: center; padding: 0.6rem; font-size: 0.8rem;">@Lang.T("home.skill.agile")</div>
                    <div class="tag" style="text-align: center; padding: 0.6rem; font-size: 0.8rem;">@Lang.T("home.skill.git")</div>
                    <div class="tag tag-teal" style="text-align: center; padding: 0.6rem; font-size: 0.8rem;">@Lang.T("home.skill.cicd")</div>
                    <div class="tag tag-orange" style="text-align: center; padding: 0.6rem; font-size: 0.8rem;">@Lang.T("home.skill.tracking")</div>
                    <div class="tag tag-red" style="text-align: center; padding: 0.6rem; font-size: 0.8rem;">@Lang.T("home.skill.cloud")</div>
                    <div class="tag tag-yellow" style="text-align: center; padding: 0.6rem; font-size: 0.8rem;">@Lang.T("home.skill.architecture")</div>
                    <div class="tag tag-light" style="text-align: center; padding: 0.6rem; font-size: 0.8rem;">@Lang.T("home.skill.api")</div>
                    <div class="tag tag-blue" style="text-align: center; padding: 0.6rem; font-size: 0.8rem;">@Lang.T("home.skill.uiux")</div>
                    <div class="tag" style="text-align: center; padding: 0.6rem; font-size: 0.8rem;">@Lang.T("home.skill.documentation")</div>
                    <div class="tag tag-teal" style="text-align: center; padding: 0.6rem; font-size: 0.8rem;">@Lang.T("home.skill.codereview")</div>
                    <div class="tag tag-orange" style="text-align: center; padding: 0.6rem; font-size: 0.8rem;">@Lang.T("home.skill.communication")</div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    protected override void OnInitialized() => Lang.OnLanguageChanged += StateHasChanged;
    public void Dispose() => Lang.OnLanguageChanged -= StateHasChanged;
}
