@page "/about"
@inject LanguageService Lang
@implements IDisposable

<PageTitle>About Me — Sébastien Bart</PageTitle>

<!-- HERO -->
<div class="page-hero">
    <div class="container">
        <h1>@Lang.T("about.hero.title")</h1>
        <p>@Lang.T("about.hero.subtitle")</p>
    </div>
</div>

<!-- BIO -->
<div class="section-full">
    <div class="section">
        <div class="grid-2" style="align-items: start;">
            <div>
                <h2 class="section-title"><span class="title-accent">—</span> @Lang.T("about.whoiam.title")</h2>
                <p style="font-size: 1.05rem; margin-bottom: 1rem;">@Lang.T("about.bio1")</p>
                <p style="font-size: 1.05rem;">@Lang.T("about.bio2")</p>
            </div>
            <div>
                <div class="card card-yellow">
                    <h3 class="card-title">@Lang.T("about.facts.title")</h3>
                    <table style="width: 100%; border-collapse: collapse; margin-top: 0.5rem;">
                        <tr style="border-bottom: 2px solid var(--dark-navy);">
                            <td style="padding: 0.5rem 0; font-weight: 700; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.5px; width: 40%;">@Lang.T("about.facts.location")</td>
                            <td style="padding: 0.5rem 0;">Ornans, France</td>
                        </tr>
                        <tr style="border-bottom: 2px solid var(--dark-navy);">
                            <td style="padding: 0.5rem 0; font-weight: 700; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.5px;">@Lang.T("about.facts.age")</td>
                            <td style="padding: 0.5rem 0;">26</td>
                        </tr>
                        <tr style="border-bottom: 2px solid var(--dark-navy);">
                            <td style="padding: 0.5rem 0; font-weight: 700; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.5px;">@Lang.T("about.facts.languages")</td>
                            <td style="padding: 0.5rem 0;">@Lang.T("about.facts.languages.value")</td>
                        </tr>
                        <tr style="border-bottom: 2px solid var(--dark-navy);">
                            <td style="padding: 0.5rem 0; font-weight: 700; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.5px;">@Lang.T("about.facts.status")</td>
                            <td style="padding: 0.5rem 0;">
                                <span class="tag tag-teal">@Lang.T("about.facts.opentowork")</span>
                            </td>
                        </tr>
                        <tr>
                            <td style="padding: 0.5rem 0; font-weight: 700; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.5px;">@Lang.T("about.facts.availability.label")</td>
                            <td style="padding: 0.5rem 0;">@Lang.T("about.facts.availability.value")</td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- HOBBIES -->
<div class="section-full section-alt">
    <div class="section">
        <h2 class="section-title"><span class="title-accent">—</span> @Lang.T("about.hobbies.title")</h2>
        <div class="grid-3">
            <div class="hobby-card" style="background-color: var(--off-white);">
                <span class="hobby-icon">🎮</span>
                <h3 class="hobby-title">@Lang.T("about.hobby.gaming.title")</h3>
                <p class="card-text">@Lang.T("about.hobby.gaming.desc")</p>
            </div>
            <div class="hobby-card card-teal">
                <span class="hobby-icon">📚</span>
                <h3 class="hobby-title">@Lang.T("about.hobby.reading.title")</h3>
                <p class="card-text">@Lang.T("about.hobby.reading.desc")</p>
            </div>
            <div class="hobby-card card-yellow">
                <span class="hobby-icon">🏋️‍♂️</span>
                <h3 class="hobby-title">@Lang.T("about.hobby.workout.title")</h3>
                <p class="card-text">@Lang.T("about.hobby.workout.desc")</p>
            </div>
            <div class="hobby-card" style="background-color: var(--light-blue);">
                <span class="hobby-icon">🗺️</span>
                <h3 class="hobby-title">@Lang.T("about.hobby.travel.title")</h3>
                <p class="card-text">@Lang.T("about.hobby.travel.desc")</p>
            </div>
        </div>
    </div>
</div>

<!-- VALUES -->
<div class="section-full">
    <div class="section">
        <h2 class="section-title"><span class="title-accent">—</span> @Lang.T("about.values.title")</h2>
        <div class="grid-3">
            <div class="card card-red">
                <h3 class="card-title">@Lang.T("about.value1.title")</h3>
                <p class="card-text">@Lang.T("about.value1.desc")</p>
            </div>
            <div class="card card-light-blue">
                <h3 class="card-title">@Lang.T("about.value2.title")</h3>
                <p class="card-text">@Lang.T("about.value2.desc")</p>
            </div>
            <div class="card" style="background-color: var(--gold);">
                <h3 class="card-title">@Lang.T("about.value3.title")</h3>
                <p class="card-text">@Lang.T("about.value3.desc")</p>
            </div>
        </div>
    </div>
</div>

@code {
    protected override void OnInitialized() => Lang.OnLanguageChanged += StateHasChanged;
    public void Dispose() => Lang.OnLanguageChanged -= StateHasChanged;
}
