@page "/projects"
@inject LanguageService Lang
@implements IDisposable

<PageTitle>Projects — Sébastien Bart</PageTitle>

<!-- HERO -->
<div class="page-hero">
    <div class="container">
        <h1>@Lang.T("projects.hero.title")</h1>
        <p>@Lang.T("projects.hero.subtitle")</p>
    </div>
</div>

<!-- FEATURED PROJECT -->
<div class="section-full">
    <div class="section">
        <h2 class="section-title"><span class="title-accent">★</span>@Lang.T("projects.featured.label")</h2>
        <div class="project-card" style="border-color: var(--dark-navy);">
            <div class="project-card-header card-yellow">
                <h3 class="card-title" style="font-size: 2rem;">1v1 me bro</h3>
                <p class="card-meta">@Lang.T("projects.featured.meta")</p>
            </div>
            <div class="project-card-body" style="background-color: var(--off-white);">
                <img src="images/1v1_me_bro.jpeg" alt="1v1 me bro" height="256px"
                     style="margin: auto; display: block; border-radius: 8px; margin-bottom: 1rem;">
                <p>@Lang.T("projects.featured.desc1")</p>
                <p style="margin-top: 0.75rem;">@Lang.T("projects.featured.desc2")</p>
            </div>
            <div class="project-card-footer" style="background-color: var(--sage); justify-content: space-between;">
                <div class="tags" style="margin: 0;">
                    <span class="tag tag-blue">Unity</span>
                    <span class="tag">C#</span>
                    <span class="tag tag-teal">Trello</span>
                    <span class="tag tag-orange">Software management</span>
                </div>
                <div style="display: flex; gap: 0.5rem; flex-shrink: 0;">
                    <a href="#" class="btn btn-primary">@Lang.T("projects.featured.btn")</a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ALL PROJECTS GRID -->
<div class="section-full section-alt">
    <div class="section">
        <h2 class="section-title"><span class="title-accent">—</span>@Lang.T("projects.all.label")</h2>
        <div class="grid-3">

            <!-- Project 1 — Dofus combat -->
            <div class="project-card">
                <div class="project-card-header card-teal">
                    <h3 class="card-title">Dofus — combat system</h3>
                    <p class="card-meta">@Lang.T("projects.p1.meta")</p>
                </div>
                <div class="project-card-body">
                    <p class="card-text">@Lang.T("projects.p1.desc")</p>
                </div>
                <div class="project-card-footer">
                    <div class="tags" style="margin: 0; flex: 1;">
                        <span class="tag tag-blue">C#</span>
                        <span class="tag">SQL / Oracle</span>
                        <span class="tag tag-teal">Java</span>
                    </div>
                </div>
            </div>

            <!-- Project 2 — Dofus UIs -->
            <div class="project-card">
                <div class="project-card-header card-orange">
                    <h3 class="card-title">Dofus — new UIs</h3>
                    <p class="card-meta">@Lang.T("projects.p2.meta")</p>
                </div>
                <div class="project-card-body">
                    <p class="card-text">@Lang.T("projects.p2.desc")</p>
                </div>
                <div class="project-card-footer">
                    <div class="tags" style="margin: 0; flex: 1;">
                        <span class="tag tag-blue">C#</span>
                        <span class="tag">HTML</span>
                        <span class="tag tag-teal">CSS</span>
                        <span class="tag tag-orange">Unity</span>
                        <span class="tag tag-red">Figma</span>
                    </div>
                </div>
            </div>

            <!-- Project 3 — Decathlon monitoring -->
            <div class="project-card">
                <div class="project-card-header card-red">
                    <h3 class="card-title">Decathlon — monitoring</h3>
                    <p class="card-meta">@Lang.T("projects.p3.meta")</p>
                </div>
                <div class="project-card-body">
                    <p class="card-text">@Lang.T("projects.p3.desc")</p>
                </div>
                <div class="project-card-footer">
                    <div class="tags" style="margin: 0; flex: 1;">
                        <span class="tag tag-blue">Splunk</span>
                        <span class="tag">SQL / PostgreSQL</span>
                        <span class="tag tag-teal">SRE</span>
                    </div>
                </div>
            </div>

            <!-- Project 4 — Picross Maker -->
            <div class="project-card">
                <div class="project-card-header card-navy">
                    <h3 class="card-title">Picross Maker</h3>
                    <p class="card-meta">@Lang.T("projects.p4.meta")</p>
                </div>
                <div class="project-card-body">
                    <p class="card-text">@Lang.T("projects.p4.desc")</p>
                </div>
                <div class="project-card-footer">
                    <div class="tags" style="margin: 0; flex: 1;">
                        <span class="tag tag-blue">C#</span>
                        <span class="tag">Unity</span>
                        <span class="tag tag-teal">Agile</span>
                    </div>
                </div>
            </div>

            <!-- Project 5 — Magic card finder -->
            <div class="project-card">
                <div class="project-card-header" style="background-color: var(--mid-blue);">
                    <h3 class="card-title" style="color: var(--off-white);">Magic card finder</h3>
                    <p class="card-meta" style="color: var(--light-blue);">@Lang.T("projects.p5.meta")</p>
                </div>
                <div class="project-card-body">
                    <p class="card-text">@Lang.T("projects.p5.desc")</p>
                </div>
                <div class="project-card-footer">
                    <div class="tags" style="margin: 0; flex: 1;">
                        <span class="tag tag-blue">Java</span>
                        <span class="tag">Android Studio</span>
                        <span class="tag tag-teal">REST API</span>
                    </div>
                </div>
            </div>

            <!-- Project 6 — VR meet -->
            <div class="project-card">
                <div class="project-card-header" style="background-color: var(--gold);">
                    <h3 class="card-title">VR meet</h3>
                    <p class="card-meta">@Lang.T("projects.p6.meta")</p>
                </div>
                <div class="project-card-body">
                    <p class="card-text">@Lang.T("projects.p6.desc")</p>
                </div>
                <div class="project-card-footer">
                    <div class="tags" style="margin: 0; flex: 1;">
                        <span class="tag tag-blue">C#</span>
                        <span class="tag">Unity</span>
                        <span class="tag tag-teal">Mirror</span>
                        <span class="tag tag-orange">Jenkins</span>
                        <span class="tag tag-red">Docker</span>
                    </div>
                </div>
            </div>

            <!-- Project 7 — This portfolio -->
            <div class="project-card">
                <div class="project-card-header" style="background-color: var(--light-blue);">
                    <h3 class="card-title">This portfolio!</h3>
                    <p class="card-meta">@Lang.T("projects.p7.meta")</p>
                </div>
                <div class="project-card-body">
                    <p class="card-text">@Lang.T("projects.p7.desc")</p>
                </div>
                <div class="project-card-footer">
                    <div class="tags" style="margin: 0; flex: 1;">
                        <span class="tag tag-blue">C#</span>
                        <span class="tag">ASP.NET</span>
                        <span class="tag tag-teal">Razor</span>
                        <span class="tag tag-orange">Blazor</span>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

@code {
    protected override void OnInitialized() => Lang.OnLanguageChanged += StateHasChanged;
    public void Dispose() => Lang.OnLanguageChanged -= StateHasChanged;
}
